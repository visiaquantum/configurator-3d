; GitHub Packages auth — route @visiaquantum scope to GitHub registry.
; Token is read from env var to avoid committing secrets. Set NODE_AUTH_TOKEN
; (or GITHUB_TOKEN in CI) to a PAT with `read:packages` (consumers) or
; `write:packages` (publishers).
@visiaquantum:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
always-auth=true
